# Copy this file to `.env` and fill in your values. `.env` is gitignored.
# Loaded automatically by `superconducted-poll` via python-dotenv.

# IBM Quantum Platform API token from https://quantum.cloud.ibm.com/account
IBM_QUANTUM_TOKEN=<your-token-here>

# IBM SDK channel. Default: ibm_quantum_platform (post-2025).
# Use ibm_quantum only when historical-property access requires the legacy
# channel and your account has it provisioned.
IBM_QUANTUM_CHANNEL=ibm_quantum_platform

# Optional hub/group/project string. Required for historical calibration
# queries on most access tiers; leave blank for the default instance.
IBM_QUANTUM_INSTANCE=

# Where snapshots are written. Default: ./data/calibration
SUPERCONDUCTED_DATA_DIR=./data/calibration

# Where rotating logs are written. Default: ./data/logs
SUPERCONDUCTED_LOG_DIR=./data/logs

# Hard cap on how far back `--historical` may look (in days).
SUPERCONDUCTED_HISTORICAL_MAX_DAYS=30

# Retry budget for transient HTTP failures.
SUPERCONDUCTED_HTTP_RETRIES=3
